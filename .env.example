# PureReason Cloud Configuration
# Copy to .env and fill in your values

# API server bind address
PURE_REASON_BIND=0.0.0.0:8080

# Comma-separated API keys for authentication (leave empty to disable auth)
# Example: PURE_REASON_API_KEYS=tenant1:key-abc123,tenant2:key-def456
PURE_REASON_API_KEYS=

# Log level: error, warn, info, debug, trace
RUST_LOG=info
